# ═══════════════════════════════════════════════════════════════════════════
# Environment template — copy to .env and fill only the provider you use
# ═══════════════════════════════════════════════════════════════════════════

# LLM provider to use. Options: groq | anthropic | openai | openrouter
LLM_PROVIDER=groq

# Default model name (provider-specific). Overridden by LLM_MODEL_OVERRIDE if set.
#   groq        → llama-3.3-70b-versatile   (free, fast)
#   anthropic   → claude-3-5-sonnet-20241022
#   openai      → gpt-4o-mini
#   openrouter  → meta-llama/llama-3.3-70b-instruct:free
LLM_MODEL_OVERRIDE=

# API keys (only fill the one matching LLM_PROVIDER)
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Embeddings — local model (no API key needed). Override to a different HF model if desired.
EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Reranker — local cross-encoder
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Qdrant (local docker by default)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=energy_papers

# Langfuse tracing (optional but recommended). Free cloud at cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Data paths
PAPERS_DIR=./data/papers
CACHE_DIR=./data/cache

# API
API_HOST=0.0.0.0
API_PORT=8000

# Logging
LOG_LEVEL=INFO
